generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Conversation {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())

  chats     Chat[]
}

model Chat {
  id             Int      @id @default(autoincrement())
  role           String
  message        String
  createdAt      DateTime @default(now())

  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}